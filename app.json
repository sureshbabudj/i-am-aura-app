{
  "expo": {
    "name": "I Am Aura - Quotes & Wallpapers",
    "slug": "i-am-aura-quotes-wallpaper",
    "version": "1.0.0",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#8FA998"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sureshbabudj.quoteswallpaper",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Save wallpapers to your photo library",
        "NSUserTrackingUsageDescription": "Track widget usage for improvements"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#8FA998"
      },
      "package": "com.sureshbabudj.quoteswallpaper",
      "permissions": [
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sharing",
      "expo-secure-store",
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "AuraWidget",
              "displayName": "Aura Quotes",
              "description": "Daily mood-based quotes",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "systemLarge",
                "accessoryCircular",
                "accessoryRectangular",
                "accessoryInline"
              ]
            }
          ],
          "groupIdentifier": "group.com.sureshbabudj.iamaura",
          "bundleIdentifier": "com.sureshbabudj.quoteswallpaper.ExpoWidgetsTarget"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": true
          }
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ExpoWidgetsTarget",
                  "bundleIdentifier": "com.sureshbabudj.quoteswallpaper.ExpoWidgetsTarget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.sureshbabudj.iamaura"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "4e6cc06e-9e2a-417d-91a2-1beeb954875d"
      }
    }
  }
}
