{
  "expo": {
    "name": "I Am Aura - Quotes & Wallpapers",
    "slug": "affirmations-wallpaper",
    "scheme": "iamaura",
    "version": "1.0.0",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#8FA998"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sureshbabudj.iamaura",
      "appleTeamId": "AVSVKZW6N8",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Save wallpapers to your photo library",
        "NSUserTrackingUsageDescription": "Track widget usage for improvements",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.security.application-groups": ["group.com.sureshbabudj.iamaura"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#8FA998"
      },
      "package": "com.sureshbabudj.iamaura",
      "permissions": ["WRITE_EXTERNAL_STORAGE", "READ_EXTERNAL_STORAGE"]
    },
    "plugins": [
      "@bacons/apple-targets",
      "expo-router",
      "expo-font",
      "expo-sharing",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": true
          }
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "4e6cc06e-9e2a-417d-91a2-1beeb954875d"
      }
    }
  }
}
