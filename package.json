{
  "name": "my-expo-app",
  "version": "1.0.0",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start",
    "prebuild": "expo prebuild",
    "prewidget": "EXPO_NO_GIT_STATUS=1 npx expo prebuild --template ./node_modules/@bacons/apple-targets/prebuild-blank.tgz --clean",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "web": "expo start --web"
  },
  "dependencies": {
    "@bacons/apple-targets": "^4.0.6",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/noto-serif": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.1.2",
    "@tanstack/react-query": "^5.95.2",
    "axios": "^1.14.0",
    "date-fns": "^4.1.0",
    "expo": "~55.0.13",
    "expo-blur": "~55.0.14",
    "expo-build-properties": "~55.0.13",
    "expo-constants": "~55.0.11",
    "expo-crypto": "~55.0.14",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image-manipulator": "~55.0.15",
    "expo-linear-gradient": "~55.0.13",
