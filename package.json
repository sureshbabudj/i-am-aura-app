    "@babel/core": "^7.20.0",
    "@types/react": "~19.2.0",
    "@types/uuid": "^11.0.0",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.2",
    "patch-package": "^8.0.1",
    "prettier": "^3.2.5",
